# Supabase cloud sync (optional). Copy this file to .env and fill in your project values.
# Find these in Supabase: Project Settings -> API.
# The anon key is safe to ship in a client app (Row Level Security protects data).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
